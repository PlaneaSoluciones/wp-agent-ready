{
	"name": "planeasoluciones/wp-agent-ready",
	"description": "WordPress plugin that exposes published content to AI agents and LLMs via a clean REST API",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Planea Soluciones Informáticas",
			"email": "info@planeasoluciones.com",
			"homepage": "https://planeasoluciones.com"
		}
	],
	"require": {
		"php": ">=8.4"
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.11",
		"wp-coding-standards/wpcs": "^3.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpstan/phpstan": "^2.1",
		"szepeviktor/phpstan-wordpress": "^2.0"
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf",
		"analyse": "phpstan analyse --memory-limit=256M",
		"check": [
			"@lint",
			"@analyse"
		]
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
