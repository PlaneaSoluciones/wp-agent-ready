<?xml version="1.0"?>
<ruleset name="WP Agent Ready">
	<description>WordPress Coding Standards for WP Agent Ready</description>

	<file>.</file>

	<arg name="basepath" value="."/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>
	<arg value="sp"/>

	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/dist/*</exclude-pattern>
	<exclude-pattern>*/includes/lib/*</exclude-pattern>

	<rule ref="WordPress">
		<!-- File names follow plugin conventions, not WP class-*.php pattern -->
		<exclude name="WordPress.Files.FileName"/>
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="wp-agent-ready"/>
			</property>
		</properties>
	</rule>
</ruleset>
